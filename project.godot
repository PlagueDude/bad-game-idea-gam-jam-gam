; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Bad Game Idea Gam Jam Gam"
run/main_scene="uid://pwhvsos1cp7i"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/show_image=false
boot_splash/use_filter=false
config/icon="res://icon.svg"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"
Gamemanager="*uid://drkevrxmtmleb"
TransitionManager="*uid://d6y7t7y7id7y"
AudioController="*uid://ca2qhyf7exc4x"

[dialogic]

directories/dch_directory={
"unit_test_character": "res://Misc/Tests/Resources/unit_test_character.dch"
}
directories/dtl_directory={
"TestLine": "res://Timelines/TestDialog/TestLine.dtl",
"TestLine2": "res://Timelines/TestDialog/TestLine2.dtl",
"TestLine3": "res://Timelines/TestDialog/TestLine3.dtl",
"TestLine5": "res://Timelines/TestDialog/TestLine5.dtl",
"Testline4": "res://Timelines/TestDialog/Testline4.dtl",
"Testline6": "res://Timelines/TestDialog/Testline6.dtl"
}
layout/style_directory={
"": "res://Timelines/Style1.tres",
"Style1": "res://Timelines/Style1.tres",
"Style2": "res://Timelines/Styles/Style2.tres",
"StyleBTS": "res://Timelines/Styles/StyleBTS.tres",
"StyleNar": "res://Timelines/Styles/StyleNar.tres"
}
layout/style_list=["res://Timelines/Style1.tres", "res://Timelines/Styles/Style2.tres", "res://Timelines/Styles/StyleNar.tres", "res://Timelines/Styles/StyleBTS.tres"]
layout/default_style="res://Timelines/Style1.tres"
glossary/default_case_sensitive=true
variables={
"TestVars": {
"Agree": false
}
}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[gui]

theme/custom_font="uid://djb12eavdvsh5"

